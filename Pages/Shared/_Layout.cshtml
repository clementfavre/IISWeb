<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <meta name="theme-color" content="#fdf3e6" />
    <title>@ViewData["Title"] - IISWeb</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    <nav class="navbar navbar-expand-md sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" asp-page="/Index">
                <svg class="iisweb-mark" width="14" height="16" viewBox="0 0 14 16" aria-hidden="true" focusable="false">
                    <path d="M11.4 1.6c1.6 2 1.7 5.2-.2 7.8-1.6 2.2-4.2 3-6.7 3l-2 2.6a.6.6 0 0 1-.95-.73L9.6 1.4c.6-.16 1.25-.05 1.8.2z"/>
                    <path d="M9.5 4.5 5 10.6" stroke="rgba(26,27,30,.35)" stroke-width=".7" stroke-linecap="round" fill="none"/>
                </svg>
                IISWeb
            </a>
            @if (User?.Identity?.IsAuthenticated == true)
            {
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item"><a class="nav-link" asp-page="/Index">Pools</a></li>
                        <li class="nav-item"><a class="nav-link" asp-page="/Audit">Audit</a></li>
                        @if (User.IsInRole(Roles.Admin))
                        {
                            <li class="nav-item"><a class="nav-link" asp-page="/Admin/Users/Index">Users</a></li>
                        }
                    </ul>
                    <ul class="navbar-nav ms-auto align-items-md-center">
                        <li class="nav-item dropdown me-md-2">
                            <a class="nav-link dropdown-toggle small" href="#"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @User.Identity.Name
                                <span class="badge text-bg-secondary ms-1">
                                    @(User.IsInRole(Roles.Admin) ? "Admin" : "Viewer")
                                </span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-page="/Account/Mfa">Two-factor</a></li>
                                <li><a class="dropdown-item" asp-page="/Account/ChangePassword">Change password</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <form method="post" asp-page="/Account/Logout" class="d-inline">
                                <button type="submit" class="btn btn-sm btn-outline-light">Logout</button>
                            </form>
                        </li>
                    </ul>
                </div>
            }
        </div>
    </nav>

    <main class="container py-4 flex-grow-1">
        @RenderBody()
    </main>

    <footer class="border-top mt-auto">
        <div class="iisweb-footer">
            <svg class="iisweb-mark iisweb-mark-soft" width="11" height="13" viewBox="0 0 14 16" aria-hidden="true" focusable="false">
                <path d="M11.4 1.6c1.6 2 1.7 5.2-.2 7.8-1.6 2.2-4.2 3-6.7 3l-2 2.6a.6.6 0 0 1-.95-.73L9.6 1.4c.6-.16 1.25-.05 1.8.2z"/>
            </svg>
            <span>IISWeb</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/confirm.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
