@page
@model IISWeb.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h1 class="h4 m-0">Users</h1>
    <a class="btn btn-primary btn-sm" asp-page="Create">+ New user</a>
</div>

@if (Model.StatusMessage is { } m)
{
    <div class="alert alert-@(Model.StatusSuccess ? "success" : "danger")" role="alert">@m</div>
}

<div class="table-responsive">
    <table class="table table-sm table-striped align-middle">
        <thead>
            <tr>
                <th>User</th>
                <th>Role</th>
                <th>MFA</th>
                <th>Status</th>
                <th>Last login</th>
                <th class="text-end"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Users)
            {
                var locked = u.LockoutUntilUtc is { } until && until > DateTime.UtcNow;
                <tr>
                    <td class="text-break">@u.UserName</td>
                    <td><span class="badge text-bg-secondary">@u.Role</span></td>
                    <td>
                        @if (u.TotpEnabled)
                        {
                            <span class="badge text-bg-success">On</span>
                        }
                        else
                        {
                            <span class="badge text-bg-light text-dark border">Off</span>
                        }
                    </td>
                    <td>
                        @if (locked)
                        {
                            <span class="badge text-bg-warning">Locked</span>
                        }
                        else if (u.MustChangePassword)
                        {
                            <span class="badge text-bg-info">Must change pwd</span>
                        }
                        else
                        {
                            <span class="text-muted small">OK</span>
                        }
                    </td>
                    <td><small>@(u.LastLoginUtc?.ToString("yyyy-MM-dd HH:mm") ?? "Never")</small></td>
                    <td class="text-end text-nowrap">
                        <a class="btn btn-outline-secondary btn-sm" asp-page="Edit" asp-route-id="@u.Id">Edit</a>
                        <a class="btn btn-outline-danger btn-sm" asp-page="Delete" asp-route-id="@u.Id">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
